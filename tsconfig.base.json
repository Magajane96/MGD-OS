{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@mgd/types": ["packages/types/src"],
      "@mgd/events": ["packages/events/src"],
      "@mgd/kernel": ["packages/kernel/src"],
      "@mgd/company-state": ["packages/company-state/src"],
      "@mgd/widgets": ["packages/widgets/src"],
      "@mgd/design-system": ["packages/design-system/src"],
      "@mgd/ui": ["packages/ui/src"],
      "@mgd/business-brain": ["packages/business-brain/src"],
      "@mgd/advisor": ["packages/advisor/src"]
    }
  }
}
